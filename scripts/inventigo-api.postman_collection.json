    {
      "name": "📦 Products",
      "item": [
        {
          "name": "List Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (Array.isArray(json) && json[0]) {",
                  "  pm.collectionVariables.set('productId', json[0].id);",
                  "  // Capture first available sizeId from product variants",
                  "  var sizes = json[0].sizes || json[0].variants || json[0].stockItems || [];",
                  "  if (sizes[0] && sizes[0].sizeId) pm.collectionVariables.set('sizeId', sizes[0].sizeId);",
                  "  if (sizes[0] && sizes[0].id && !sizes[0].sizeId) pm.collectionVariables.set('sizeId', sizes[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw":   "{{baseUrl}}/api/products",
              "host":  ["{{baseUrl}}"],
              "path":  ["api", "products"],
              "query": [
                { "key": "search",     "value": "",     "disabled": true },
                { "key": "categoryId", "value": "",     "disabled": true },
                { "key": "brandId",    "value": "",     "disabled": true },
                { "key": "isActive",   "value": "true", "disabled": true }
              ]
            },
            "header": [{ "key": "Cookie", "value": "{{sessionCookie}}" }],
            "description": "Query params: search, categoryId, brandId, isActive"
          }
        },
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) pm.collectionVariables.set('productId', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url":    "{{baseUrl}}/api/products",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie",       "value": "{{sessionCookie}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Classic White T-Shirt\",\n  \"sku\": \"TSH-WHT-001\",\n  \"description\": \"100% cotton classic white tee\",\n  \"costPrice\": 250,\n  \"sellPrice\": 599,\n  \"categoryId\": \"{{categoryId}}\",\n  \"brandId\": \"{{brandId}}\",\n  \"externalBarcode\": \"8901234567890\",\n  \"imageUrl\": null\n}"
            },
            "description": "Required: name, sku, categoryId, brandId. Optional: description, costPrice, sellPrice, externalBarcode, imageUrl."
          }
        },
        {
          "name": "Get Product by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "// Capture sizeId from product detail — try multiple response shapes",
                  "var sizes = json.sizes || json.variants || json.stockItems || json.productSizes || [];",
                  "if (sizes[0]) {",
                  "  var sid = sizes[0].sizeId || sizes[0].id;",
                  "  if (sid) { pm.collectionVariables.set('sizeId', sid); console.log('sizeId set: ' + sid); }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url":    "{{baseUrl}}/api/products/{{productId}}",
            "header": [{ "key": "Cookie", "value": "{{sessionCookie}}" }]
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "url":    "{{baseUrl}}/api/products/{{productId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie",       "value": "{{sessionCookie}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Classic White T-Shirt (Updated)\",\n  \"sellPrice\": 649,\n  \"description\": \"Premium 100% cotton — now with updated fabric\",\n  \"isActive\": true\n}"
            }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "url":    "{{baseUrl}}/api/products/{{productId}}",
            "header": [{ "key": "Cookie", "value": "{{sessionCookie}}" }]
          }
        }
      ]
