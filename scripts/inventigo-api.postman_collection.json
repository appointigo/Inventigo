{
  "info": {
    "name": "Stockiva API",
    "description": "Full API collection for Stockiva — multi-tenant retail inventory management.\n\n## Setup\n1. Import this collection into Postman.\n2. Set the `baseUrl` variable to `http://localhost:3000`.\n3. Run **Auth → Sign In** first — the response sets `sessionCookie` automatically via the test script.\n4. All subsequent requests use `{{sessionCookie}}` in the Cookie header.\n\n## Test Credentials\n| Role | Email | Password |\n|------|-------|----------|\n| OWNER | owner@stockiva.com | password123 |\n| ADMIN | admin@stockiva.com | password123 |\n| MANAGER | manager@stockiva.com | password123 |\n| STAFF | staff@stockiva.com | password123 |\n| SUPER_ADMIN | superadmin@stockiva.com | password123 |",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",       "value": "http://localhost:3000",  "type": "string" },
    { "key": "sessionCookie", "value": "",                        "type": "string" },
    { "key": "orgId",         "value": "",  "type": "string" },
    { "key": "productId",     "value": "",  "type": "string" },
    { "key": "categoryId",    "value": "",  "type": "string" },
    { "key": "brandId",       "value": "",  "type": "string" },
    { "key": "supplierId",    "value": "",  "type": "string" },
    { "key": "storeId",       "value": "",  "type": "string" },
    { "key": "poId",          "value": "",  "type": "string" },
    { "key": "saleId",        "value": "",  "type": "string" },
    { "key": "userId",        "value": "",  "type": "string" },
    { "key": "alertId",       "value": "",  "type": "string" },
    { "key": "inviteToken",   "value": "",  "type": "string" },
    { "key": "sizeId",        "value": "",  "type": "string" },
    { "key": "adminOrgId",    "value": "",  "type": "string" }
  ],
  "item": [

    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Get CSRF Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('csrfToken', json.csrfToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url":    "{{baseUrl}}/api/auth/csrf",
            "description": "Fetch a CSRF token — required before Sign In."
          }
        },
        {
          "name": "Sign In",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Extract the session cookie from Set-Cookie header",
                  "var cookies = pm.response.headers.get('Set-Cookie') || '';",
                  "var match = cookies.match(/((?:authjs|next-auth|__Secure-authjs|__Secure-next-auth)\\.session-token=[^;]+)/);",
                  "if (match) {",
                  "  pm.collectionVariables.set('sessionCookie', match[1]);",
                  "  console.log('Session cookie saved: ' + match[1].substring(0, 40) + '...');",
                  "} else {",
                  "  console.warn('No session cookie found. Check credentials.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url":    "{{baseUrl}}/api/auth/callback/credentials",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "email",       "value": "owner@stockiva.com" },
                { "key": "password",    "value": "password123" },
                { "key": "csrfToken",   "value": "{{csrfToken}}" },
                { "key": "callbackUrl", "value": "{{baseUrl}}" },
                { "key": "redirect",    "value": "false" }
              ]
            },
            "description": "Authenticates with credentials. Run 'Get CSRF Token' first.\nAuto-saves the session cookie to {{sessionCookie}}."
          }
        },
        {
          "name": "Get Session",
          "request": {
            "method": "GET",
            "url":    "{{baseUrl}}/api/auth/session",
            "header": [{ "key": "Cookie", "value": "{{sessionCookie}}" }],
            "description": "Returns the currently authenticated user from the JWT session."
          }
        },
        {
          "name": "Register New Organization",
          "request": {
            "method": "POST",
            "url":    "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orgName\": \"My Retail Store\",\n  \"ownerName\": \"John Doe\",\n  \"email\": \"john.doe@myretail.com\",\n  \"password\": \"SecurePass123\"\n}"
            },
            "description": "Creates a new Organization + OWNER user + default Store in one transaction.\nRequired fields: orgName, ownerName, email, password (min 8 chars)"
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "url":    "{{baseUrl}}/api/auth/forgot-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@stockiva.com\"\n}"
            },
            "description": "Initiates password reset. In demo mode always returns 200."
          }
        }
      ]
    },

