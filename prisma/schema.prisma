generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                     String                  @id @default(uuid())
  name                   String
  slug                   String                  @unique
  logoUrl                String?
  plan                   OrgPlan                 @default(FREE)
  isActive               Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  alertConfigs           AlertConfig[]
  brands                 Brand[]
  categories             Category[]
  customers              Customer[]
  expenseBudgets         ExpenseBudget[]
  expenseCategoryOptions ExpenseCategoryOption[]
  featureFlags           FeatureFlag[]
  invitations            Invitation[]
  leaveBalances          LeaveBalance[]
  leaveRequests          LeaveRequest[]
  products               Product[]
  promoCodes             PromoCode[]
  attendances            StaffAttendance[]
  storeExpenses          StoreExpense[]
  leavePolicies          StoreLeavePolicy[]
  stores                 Store[]
  suppliers              Supplier[]
  users                  User[]
  weeklyOffs             WeeklyOff[]

  @@map("organizations")
}

model Store {
  id             String             @id @default(uuid())
  orgId          String
  name           String
  code           String
  address        String?
  phone          String?
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  alertConfigs   AlertConfig[]
  brands         Brand[]
  categories     Category[]
  expenseBudgets ExpenseBudget[]
  invitations    Invitation[]
  leaveRequests  LeaveRequest[]
  purchaseOrders PurchaseOrder[]
  sales          Sale[]
  returnTransactions ReturnTransaction[]
  attendances    StaffAttendance[]
  stockEntries   StockEntry[]
  stockMovements StockMovement[]
  storeExpenses  StoreExpense[]
  leavePolicies  StoreLeavePolicy[]
  org            Organization       @relation(fields: [orgId], references: [id])
  users          User[]
  weeklyOffs     WeeklyOff[]

  @@unique([code, orgId])
  @@index([orgId])
  @@map("stores")
}

model User {
  id              String            @id @default(uuid())
  orgId           String?
  name            String
  email           String            @unique
  passwordHash    String
  role            Role              @default(STAFF)
  storeId         String?
  isActive        Boolean           @default(true)
  emailVerified   Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  createdColors   Color[]
  sentInvitations Invitation[]      @relation("SentInvitations")
  leaveBalances   LeaveBalance[]
  reviewedLeaves  LeaveRequest[]    @relation("LeaveReviewer")
  leaveRequests   LeaveRequest[]    @relation("LeaveRequester")
  purchaseOrders  PurchaseOrder[]
  sales           Sale[]
  salePayments    SalePayment[]
  returnTransactions ReturnTransaction[]
  attendances     StaffAttendance[]
  stockMovements  StockMovement[]
  storeExpenses   StoreExpense[]
  org             Organization?     @relation(fields: [orgId], references: [id])
  store           Store?            @relation(fields: [storeId], references: [id])

  @@index([orgId])
  @@map("users")
}

model Invitation {
  id        String           @id @default(uuid())
  orgId     String
  storeId   String?
  email     String
  role      Role
  invitedBy String
  status    InvitationStatus @default(PENDING)
  token     String           @unique
  expiresAt DateTime
  createdAt DateTime         @default(now())
  inviter   User             @relation("SentInvitations", fields: [invitedBy], references: [id])
  org       Organization     @relation(fields: [orgId], references: [id])
  store     Store?           @relation(fields: [storeId], references: [id])

  @@index([orgId])
  @@index([storeId])
  @@index([email])
  @@map("invitations")
}

model Color {
  id        String          @id
  name      String          @unique
  hex       String          @unique
  category  String
  semantic  String?
  source    ColorSourceType
  aliases   String[]
  createdBy String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  creator   User            @relation(fields: [createdBy], references: [id])

  @@index([category])
  @@index([semantic])
  @@index([createdBy])
  @@map("colors")
}

model Category {
  id              String        @id @default(uuid())
  orgId           String
  storeId         String?
  name            String
  slug            String
  description     String?
  attributeSchema Json          @default("{}")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  alertConfigs    AlertConfig[]
  org             Organization  @relation(fields: [orgId], references: [id])
  store           Store?        @relation(fields: [storeId], references: [id])
  products        Product[]
  sizes           Size[]

  @@unique([name, orgId])
  @@unique([slug, orgId])
  @@index([orgId])
  @@index([storeId])
  @@map("categories")
}

model Brand {
  id        String       @id @default(uuid())
  orgId     String
  storeId   String?
  name      String
  logoUrl   String?
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  org       Organization @relation(fields: [orgId], references: [id])
  store     Store?       @relation(fields: [storeId], references: [id])
  products  Product[]

  @@unique([name, orgId])
  @@index([orgId])
  @@index([storeId])
  @@map("brands")
}

model Product {
  id                 String              @id @default(uuid())
  orgId              String
  name               String
  sku                String
  externalBarcode    String?
  categoryId         String
  brandId            String
  basePrice          Decimal             @db.Decimal(10, 2)
  costPrice          Decimal             @db.Decimal(10, 2)
  attributes         Json                @default("{}")
  imageUrl           String?
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  mrp                Decimal             @db.Decimal(10, 2)
  brand              Brand               @relation(fields: [brandId], references: [id])
  category           Category            @relation(fields: [categoryId], references: [id])
  org                Organization        @relation(fields: [orgId], references: [id])
  purchaseOrderItems PurchaseOrderItem[]
  saleItems          SaleItem[]
  stockEntries       StockEntry[]
  stockMovements     StockMovement[]
  returnedItems      ReturnTransactionItem[] @relation("ReturnedProduct")
  newItems           ReturnTransactionItem[] @relation("NewProduct")

  @@unique([sku, orgId])
  @@index([orgId])
  @@index([categoryId])
  @@index([brandId])
  @@index([sku])
  @@map("products")
}

model Size {
  id                 String              @id @default(uuid())
  label              String
  sortOrder          Int                 @default(0)
  categoryId         String
  createdAt          DateTime            @default(now())
  purchaseOrderItems PurchaseOrderItem[]
  saleItems          SaleItem[]
  category           Category            @relation(fields: [categoryId], references: [id])
  stockEntries       StockEntry[]
  stockMovements     StockMovement[]
  returnedItems      ReturnTransactionItem[] @relation("ReturnedSize")
  newItems           ReturnTransactionItem[] @relation("NewSize")

  @@unique([label, categoryId])
  @@index([categoryId])
  @@map("sizes")
}

model StockEntry {
  id              String    @id @default(uuid())
  productId       String
  sizeId          String
  storeId         String
  variantSku      String?
  quantity        Int       @default(0)
  reorderLevel    Int       @default(5)
  reorderQuantity Int       @default(10)
  lastRestockedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  product         Product   @relation(fields: [productId], references: [id])
  size            Size      @relation(fields: [sizeId], references: [id])
  store           Store     @relation(fields: [storeId], references: [id])

  @@unique([productId, sizeId, storeId])
  @@index([storeId])
  @@index([productId])
  @@map("stock_entries")
}

model StockMovement {
  id            String            @id @default(uuid())
  productId     String
  sizeId        String
  storeId       String
  type          StockMovementType
  quantity      Int
  reason        String?
  referenceType ReferenceType?
  referenceId   String?
  createdBy     String
  movementDate  DateTime          @default(now())
  createdAt     DateTime          @default(now())
  user          User              @relation(fields: [createdBy], references: [id])
  product       Product           @relation(fields: [productId], references: [id])
  size          Size              @relation(fields: [sizeId], references: [id])
  store         Store             @relation(fields: [storeId], references: [id])

  @@index([productId])
  @@index([storeId])
  @@index([movementDate])
  @@index([createdAt])
  @@index([referenceType, referenceId])
  @@map("stock_movements")
}

model Supplier {
  id             String          @id @default(uuid())
  orgId          String
  name           String
  contactPerson  String?
  email          String?
  phone          String?
  address        String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  purchaseOrders PurchaseOrder[]
  org            Organization    @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@map("suppliers")
}

model PurchaseOrder {
  id          String              @id @default(uuid())
  storeId     String
  supplierId  String
  status      PurchaseOrderStatus @default(DRAFT)
  totalAmount Decimal             @default(0) @db.Decimal(10, 2)
  notes       String?
  orderedAt   DateTime?
  receivedAt  DateTime?
  createdBy   String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  items       PurchaseOrderItem[]
  user        User                @relation(fields: [createdBy], references: [id])
  store       Store               @relation(fields: [storeId], references: [id])
  supplier    Supplier            @relation(fields: [supplierId], references: [id])

  @@index([storeId])
  @@index([supplierId])
  @@index([status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  productId       String
  sizeId          String
  quantity        Int
  unitCost        Decimal       @db.Decimal(10, 2)
  createdAt       DateTime      @default(now())
  product         Product       @relation(fields: [productId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  size            Size          @relation(fields: [sizeId], references: [id])

  @@map("purchase_order_items")
}

model Sale {
  id             String        @id @default(uuid())
  storeId        String
  invoiceNumber  String        @unique
  customerName   String?
  customerPhone  String?
  customerEmail  String?
  subtotal       Decimal       @db.Decimal(10, 2)
  discountAmount Decimal       @default(0) @db.Decimal(10, 2)
  taxAmount      Decimal       @default(0) @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  paymentMethod  PaymentMethod @default(CASH)
  status         SaleStatus    @default(COMPLETED)
  paymentStatus  PaymentStatus @default(PAID)
  amountPaid     Decimal       @default(0) @db.Decimal(10, 2)
  amountDue      Decimal       @default(0) @db.Decimal(10, 2)
  returnStatus   ReturnStatus  @default(NONE)
  promoVoided    Boolean       @default(false)
  createdBy      String
  transactionDate DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  promoCodeId    String?
  customerId     String?
  items          SaleItem[]
  payments       SalePayment[]
  returnTransactions ReturnTransaction[]
  user           User          @relation(fields: [createdBy], references: [id])
  customer       Customer?     @relation(fields: [customerId], references: [id])
  promoCode      PromoCode?    @relation(fields: [promoCodeId], references: [id])
  store          Store         @relation(fields: [storeId], references: [id])

  @@index([storeId])
  @@index([customerId])
  @@index([createdAt])
  @@index([status])
  @@index([promoCodeId])
  @@map("sales")
}

model SaleItem {
  id        String   @id @default(uuid())
  saleId    String
  productId String
  sizeId    String
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2)
  total     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  size      Size     @relation(fields: [sizeId], references: [id])

  @@map("sale_items")
}

model SalePayment {
  id        String        @id @default(uuid())
  saleId    String
  amount    Decimal       @db.Decimal(10, 2)
  method    PaymentMethod
  businessDate DateTime   @default(now())
  paidAt    DateTime      @default(now())
  note      String?
  createdBy String
  sale      Sale          @relation(fields: [saleId], references: [id])
  user      User          @relation(fields: [createdBy], references: [id])

  @@index([saleId])
  @@index([businessDate])
  @@index([paidAt])
  @@map("sale_payments")
}

model ReturnTransaction {
  id               String        @id @default(uuid())
  referenceNumber  String        @unique
  originalSaleId   String
  storeId          String
  customerId       String?
  type             ReturnType
  netAmount        Decimal       @db.Decimal(10, 2)
  offsetAmount     Decimal       @default(0) @db.Decimal(10, 2)
  refundAmount     Decimal       @db.Decimal(10, 2)
  refundMethod     String?
  reason           String?
  condition        String?
  notes            String?
  businessDate     DateTime      @default(now())
  createdAt        DateTime      @default(now())
  createdBy        String
  items            ReturnTransactionItem[]
  sale             Sale          @relation(fields: [originalSaleId], references: [id])
  customer         Customer?     @relation(fields: [customerId], references: [id])
  user             User          @relation(fields: [createdBy], references: [id])
  store            Store         @relation(fields: [storeId], references: [id])

  @@index([originalSaleId])
  @@index([storeId])
  @@index([customerId])
  @@index([businessDate])
  @@index([createdAt])
  @@map("return_transactions")
}

model ReturnTransactionItem {
  id                   String            @id @default(uuid())
  returnTransactionId  String
  returnedProductId    String?
  returnedSizeId       String?
  returnedQuantity     Int
  returnedUnitPrice    Decimal           @db.Decimal(10, 2)
  newProductId         String?
  newSizeId            String?
  newQuantity          Int?
  newUnitPrice         Decimal?          @db.Decimal(10, 2)
  createdAt            DateTime          @default(now())
  returnTransaction    ReturnTransaction @relation(fields: [returnTransactionId], references: [id])
  returnedProduct      Product?          @relation("ReturnedProduct", fields: [returnedProductId], references: [id])
  returnedSize         Size?             @relation("ReturnedSize", fields: [returnedSizeId], references: [id])
  newProduct           Product?          @relation("NewProduct", fields: [newProductId], references: [id])
  newSize              Size?             @relation("NewSize", fields: [newSizeId], references: [id])

  @@index([returnTransactionId])
  @@index([returnedProductId])
  @@index([newProductId])
  @@map("return_transaction_items")
}

model Customer {
  id        String       @id @default(uuid())
  orgId     String
  name      String?
  mobile    String
  email     String?
  dateOfBirth DateTime?
  notes     String?
  lastVisitAt DateTime?
  totalSpent Float      @default(0)
  totalVisits Int       @default(0)
  tags      String[]    @default([])
  metadata  Json?
  createdAt DateTime     @default(now())
  org       Organization @relation(fields: [orgId], references: [id])
  sales     Sale[]
  returnTransactions ReturnTransaction[]

  @@unique([orgId, mobile])
  @@index([orgId])
  @@index([mobile])
  @@map("customers")
}

model AlertConfig {
  id          String       @id @default(uuid())
  orgId       String
  storeId     String?
  productId   String?
  categoryId  String?
  threshold   Int          @default(5)
  notifyEmail Boolean      @default(true)
  notifySMS   Boolean      @default(false)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  category    Category?    @relation(fields: [categoryId], references: [id])
  org         Organization @relation(fields: [orgId], references: [id])
  store       Store?       @relation(fields: [storeId], references: [id])

  @@index([orgId])
  @@map("alert_configs")
}

model PromoCode {
  id          String       @id @default(uuid())
  orgId       String
  code        String
  label       String
  desc        String       @default("")
  discountPct Decimal      @db.Decimal(5, 2)
  isActive    Boolean      @default(true)
  maxUses     Int?
  usageCount  Int          @default(0)
  expiresAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sales       Sale[]

  @@unique([code, orgId])
  @@index([orgId])
  @@map("promo_codes")
}

model ExpenseCategoryOption {
  id        String       @id @default(uuid())
  orgId     String
  name      String
  colorKey  String       @default("default")
  createdAt DateTime     @default(now())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, name])
  @@index([orgId])
  @@map("expense_category_options")
}

model StoreExpense {
  id             String       @id @default(uuid())
  orgId          String
  storeId        String
  category       String
  amount         Decimal      @db.Decimal(10, 2)
  date           DateTime     @db.Date
  note           String?
  paymentMode    String?
  receiptUrl     String?
  status         String       @default("APPROVED")
  isRecurring    Boolean      @default(false)
  recurrenceFreq String?
  vendorGstin    String?
  gstRate        Decimal?     @db.Decimal(5, 2)
  gstAmount      Decimal?     @db.Decimal(10, 2)
  isItcEligible  Boolean      @default(false)
  createdBy      String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [createdBy], references: [id])
  org            Organization @relation(fields: [orgId], references: [id])
  store          Store        @relation(fields: [storeId], references: [id])

  @@index([orgId])
  @@index([storeId])
  @@index([date])
  @@index([status])
  @@map("store_expenses")
}

model ExpenseBudget {
  id        String       @id @default(uuid())
  orgId     String
  storeId   String
  category  String
  month     Int
  year      Int
  amount    Decimal      @db.Decimal(10, 2)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  store     Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, category, month, year])
  @@index([orgId])
  @@index([storeId])
  @@map("expense_budgets")
}

model EmailVerification {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email])
  @@map("email_verifications")
}

model StaffAttendance {
  id             String           @id @default(uuid())
  orgId          String
  storeId        String
  userId         String
  date           DateTime         @db.Date
  status         AttendanceStatus @default(PRESENT)
  checkInAt      DateTime?
  checkOutAt     DateTime?
  totalMinutes   Int?
  note           String?
  source         String           @default("SYSTEM")
  overrideReason String?
  overriddenBy   String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  org            Organization     @relation(fields: [orgId], references: [id])
  store          Store            @relation(fields: [storeId], references: [id])
  user           User             @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([orgId, storeId, date])
  @@index([userId, date])
  @@map("staff_attendances")
}

model LeaveRequest {
  id              String       @id @default(uuid())
  orgId           String
  storeId         String
  userId          String
  leaveType       LeaveType
  startDate       DateTime     @db.Date
  endDate         DateTime     @db.Date
  reason          String
  status          LeaveStatus  @default(PENDING)
  reviewerComment String?
  reviewedBy      String?
  decidedAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  org             Organization @relation(fields: [orgId], references: [id])
  reviewer        User?        @relation("LeaveReviewer", fields: [reviewedBy], references: [id])
  store           Store        @relation(fields: [storeId], references: [id])
  user            User         @relation("LeaveRequester", fields: [userId], references: [id])

  @@index([orgId, storeId, status])
  @@index([userId, startDate, endDate])
  @@map("leave_requests")
}

model WeeklyOff {
  id         String       @id @default(uuid())
  orgId      String
  storeId    String
  dayOfWeek  Int
  isOptional Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  org        Organization @relation(fields: [orgId], references: [id])
  store      Store        @relation(fields: [storeId], references: [id])

  @@unique([storeId, dayOfWeek])
  @@index([orgId, storeId])
  @@map("weekly_offs")
}

model StoreLeavePolicy {
  id        String       @id @default(uuid())
  orgId     String
  storeId   String
  leaveType LeaveType
  allocated Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  org       Organization @relation(fields: [orgId], references: [id])
  store     Store        @relation(fields: [storeId], references: [id])

  @@unique([storeId, leaveType])
  @@index([orgId, storeId])
  @@map("store_leave_policies")
}

model LeaveBalance {
  id           String       @id @default(uuid())
  orgId        String
  userId       String
  leaveType    LeaveType
  year         Int
  allocated    Int          @default(0)
  used         Int          @default(0)
  carryForward Int          @default(0)
  updatedAt    DateTime     @updatedAt
  org          Organization @relation(fields: [orgId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([userId, leaveType, year])
  @@index([orgId, userId])
  @@map("leave_balances")
}

model AdminAuditLog {
  id          String   @id @default(uuid())
  action      String
  targetType  String
  targetId    String
  targetName  String?
  performedBy String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([action])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

model FeatureFlag {
  id          String        @id @default(uuid())
  orgId       String?
  key         String
  value       Boolean       @default(false)
  scope       String        @default("GLOBAL")
  description String        @default("")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  org         Organization? @relation(fields: [orgId], references: [id])

  @@unique([orgId, key])
  @@index([key])
  @@map("feature_flags")
}

model Announcement {
  id          String    @id @default(uuid())
  title       String
  body        String
  severity    String    @default("INFO")
  targetPlan  String?
  activeFrom  DateTime  @default(now())
  activeUntil DateTime?
  isActive    Boolean   @default(true)
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive])
  @@index([createdAt])
  @@map("announcements")
}

enum Role {
  SUPER_ADMIN
  OWNER
  ADMIN
  MANAGER
  STAFF
}

enum OrgPlan {
  FREE
  PRO
  ENTERPRISE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  SALE
  RETURN
  EXCHANGE_IN
  EXCHANGE_OUT
}

enum ReferenceType {
  PO
  SALE
  MANUAL
  RETURN
  EXCHANGE
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  RECEIVED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
}

enum SaleStatus {
  COMPLETED
  REFUNDED
  EXCHANGED
}

enum PaymentStatus {
  PAID
  PARTIAL
  PENDING
}

enum ReturnStatus {
  NONE
  PARTIAL
  FULL
}

enum ReturnType {
  RETURN
  EXCHANGE
  RETURN_EXCHANGE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  OFF
  LEAVE
}

enum LeaveType {
  SICK
  CASUAL
  PAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ColorSourceType {
  PREDEFINED
  USER_CREATED
  AUTO_GENERATED
}
